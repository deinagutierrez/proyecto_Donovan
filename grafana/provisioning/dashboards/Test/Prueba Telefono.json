        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH alerta_reciente AS (\n  SELECT \n    '⚠️ ALERTA (' || TO_CHAR(fecha_hora_alerta, 'HH24:MI') || 'h)' as estado,\n    ROUND(velocidad_viento * 3.6, 1) || ' km/h' as velocidad\n  FROM alertas_viento \n  WHERE id_estacion = 22 \n    AND fecha_hora_alerta >= (NOW() - INTERVAL '12 hours')\n  ORDER BY fecha_hora_alerta DESC \n  LIMIT 1\n)\nSELECT estado, velocidad FROM alerta_reciente\nUNION ALL\nSELECT 'SIN ALERTA', ''\nWHERE NOT EXISTS (SELECT 1 FROM alerta_reciente)\nLIMIT 1;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
