          "rawQuery": true,
          "rawSql": "(SELECT '⚠️ ALERTA (' || TO_CHAR(fecha_hora_alerta, 'HH24:MI') || 'h)' as \"E\", ROUND(velocidad_viento * 3.6, 1) || ' km/h' as \"V\" FROM alertas_viento WHERE id_estacion IN (26, 52, 14) AND (direccion_viento >= 135 AND direccion_viento <= 225) AND fecha_hora_alerta >= NOW() - INTERVAL '12 hours' ORDER BY fecha_hora_alerta DESC LIMIT 1) UNION ALL SELECT 'SIN ALERTA', '' WHERE NOT EXISTS (SELECT 1 FROM alertas_viento WHERE id_estacion IN (26, 52, 14) AND (direccion_viento >= 135 AND direccion_viento <= 225) AND fecha_hora_alerta >= NOW() - INTERVAL '12 hours') LIMIT 1;",
