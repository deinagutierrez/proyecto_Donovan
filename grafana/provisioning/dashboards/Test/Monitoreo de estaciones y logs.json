          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  nombre AS \"Estación\",\n  now() - max(fecha_hora) AS \"Tiempo sin reporte\"\nFROM datos_rem_temp\nJOIN estaciones_rem ON datos_rem_temp.id_estacion = estaciones_rem.id_estacion\nGROUP BY nombre\nHAVING max(fecha_hora) < now() - INTERVAL '1 hours'\nORDER BY max(fecha_hora) ASC;",
